# Storage Service di Archivematica
SS_BASE_URL=http://localhost:8000
SS_USERNAME=archivematica
SS_API_KEY=

# Opzionale: percorso di un certificato CA/self-signed, se lo Storage Service
# usa HTTPS con un certificato non firmato da un'autorita' pubblica.
# Esempio: SS_CA_CERT=./certs/storage_service.pem
SS_CA_CERT=

# Opzionale: impostare a 1 solo se il certificato e' valido ma associato a un
# nome host diverso da quello contattato (es. server duplicati con lo stesso
# certificato). Da usare con consapevolezza, solo su reti fidate.
SS_IGNORE_HOSTNAME=

# Parametri richiesti da delete_aips.py
SS_PIPELINE_UUID=
SS_USER_ID=
SS_USER_EMAIL=
