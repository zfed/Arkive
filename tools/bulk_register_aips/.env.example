# Copia questo file in .env e valorizza i campi.
# .env NON deve mai essere committato (già escluso dal .gitignore di repo).

# URL base della Storage Service (con porta, es. https://192.168.139.39:8000)
SS_URL=https://192.168.139.39:8000

# Utente API della Storage Service
SS_USER=archivematica

# API key dell'utente sopra (Storage Service > il tuo utente > API key)
SS_API_KEY=

# Verifica del certificato SSL della Storage Service.
# Impostare a "false" se si usa un certificato self-signed (come su UNIMI).
SSL_VERIFY=false

# UUID della location AIP Storage di destinazione dove gli AIP orfani
# devono risultare registrati (Storage Service > Locations).
TARGET_LOCATION_UUID=

# UUID della pipeline (istanza Archivematica) a cui attribuire gli AIP
# registrati. Obbligatorio. Lo trovi con:
#   curl -s "http://SS_HOST:8000/api/v2/pipeline/" -H "Authorization: ApiKey UTENTE:API_KEY"
# oppure nel Dashboard in Administration > General.
PIPELINE_UUID=
